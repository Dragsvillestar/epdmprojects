doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title EPDM LTD
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css", rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="/style.css")
  body
    #overall-div
      .top-section
        .b-img
          .header-container.p-3
            .logo-area.text-start
              .d-flex.align-items-center#hk
                img.img-fluid.mx-2#headerlogo(src="https://raw.githubusercontent.com/Dragsvillestar/new-git/refs/heads/master/IMG-20250125-WA0011%20(1).jpg", alt="Company Logo")
                .d-flex.flex-column
                  h1.mb-0.fw-bold ENERGY PROJECTS DATA MEDIA LTD.
                  p.p-2.rounded#logocaption
                    i your reliable and realtime energy projects market place
      nav.navbar.navbar-expand-lg.bg-dark.navbar-dark.pb-2#topnav
        .container
          button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navmenu")
            span.navbar-toggler-icon
          .collapse.navbar-collapse#navmenu
            ul.navbar-nav.ms-auto
              li.nav-item.dropdown.mx-3.fw-bold.topnavItem
                a.nav-link.dropdown-toggle.f-2(href="#", role="button", data-bs-toggle="dropdown", aria-expanded="false") ⚙️ Settings
                ul.dropdown-menu
                  li
                    a.dropdown-item#profile(href="#") Profile
                  li
                    a.dropdown-item(href="#") Manage Account
                  li
                    a.dropdown-item#logOut(href="#") Log Out
              li.nav-item.fw-bold.topnavItem
                a.nav-link.mx-3#helpButton(href="#") ❓ Help
                a.nav-link.mx-3#subscribeButton(href="#") Subscribe 
      #bottom-section
        .sideBar
          .navbar.d-flex.justify-content-center#navbar-div2
            ul.navbar-nav.text-center.flex-column.p-2
              li.nav-item
                a.nav-link(href="/home") Home
              li.nav-item
                a.nav-link#projectsmenu(href="#") Projects
              li.nav-item
                a.nav-link(href="#") News
              li.nav-item
                a.nav-link(href="#") Subscriptions
              li.nav-item
                a.nav-link(href="#") Favourites
        .projects.p-2
          h2#welcomeMsg Welcome, #{username}
          .content-div.p-3
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js", integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz", crossorigin="anonymous")
    script(src="./homepage.js")
